{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "display_name": { "type": "string" },
        "email": { "type": "string" },
        "total_cp": { "type": "number" },
        "role": { "type": "string", "enum": ["player", "admin"] }
      },
      "required": ["display_name", "email", "total_cp", "role"]
    },
    "TeamLine": {
      "title": "Team Line",
      "description": "MLB Team Over/Under line and current stats",
      "type": "object",
      "properties": {
        "team_name": { "type": "string" },
        "abbreviation": { "type": "string" },
        "ou_line": { "type": "number" },
        "stats": {
          "type": "object",
          "properties": {
            "wins": { "type": "number" },
            "losses": { "type": "number" },
            "hrs": { "type": "number" },
            "ks": { "type": "number" }
          }
        },
        "last_sync": { "type": "string", "format": "date-time" }
      },
      "required": ["team_name", "abbreviation", "ou_line", "stats"]
    },
    "Contest": {
      "title": "Contest",
      "description": "Season-long or Monthly Sprint contest",
      "type": "object",
      "properties": {
        "theme_name": { "type": "string" },
        "metric_key": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time", "description": "Stored as Firestore Timestamp" },
        "end_time": { "type": "string", "format": "date-time", "description": "Stored as Firestore Timestamp" },
        "is_active": { "type": "boolean" },
        "is_draft": { "type": "boolean" },
        "selection_limit": { "type": "number" },
        "use_chips": { "type": "boolean" },
        "draft_order": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of user UIDs in draft order"
        },
        "current_turn_index": { "type": "number" },
        "draft_status": { "type": "string", "enum": ["pending", "in_progress", "completed"] }
      },
      "required": ["theme_name", "metric_key", "start_time", "end_time", "is_active", "is_draft", "selection_limit", "use_chips"]
    },
    "Entry": {
      "title": "Entry",
      "description": "User entry for a specific contest",
      "type": "object",
      "properties": {
        "selections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "team_id": { "type": "string" },
              "chips": { "type": "number" },
              "side": { "type": "string", "enum": ["over", "under"] }
            }
          }
        },
        "score": { "type": "number" },
        "is_valid": { "type": "boolean" },
        "last_updated": { "type": "string", "format": "date-time" }
      },
      "required": ["selections", "score", "is_valid", "last_updated"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "last_updated": { "type": "string", "format": "date-time" },
        "updated_by": { "type": "string" }
      },
      "required": ["enabled", "last_updated"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/team_lines/{teamId}": { "schema": "TeamLine", "description": "MLB team data" },
    "/contests/{id}": { "schema": "Contest", "description": "Contest definitions" },
    "/contests/{id}/entries/{uid}": { "schema": "Entry", "description": "User entries for contests" },
    "/settings/{id}": { "schema": "Settings", "description": "Global app settings" }
  }
}
