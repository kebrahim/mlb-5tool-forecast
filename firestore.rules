rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - display_name: string
    //   - email: string
    //   - total_cp: number
    //   - role: string ("player", "admin")
    //
    // Collection: contests
    // Fields:
    //   - theme_name: string
    //   - metric_key: string
    //   - start_time: timestamp (or string)
    //   - end_time: timestamp (or string)
    //   - is_active: bool
    //   - is_draft: bool
    //   - selection_limit: number
    //   - use_chips: bool
    //   - draft_status: string ("pending", "in_progress", "completed")
    //   - current_turn_index: number
    //   - draft_order: list (strings)
    //
    // Collection: contests/{id}/entries/{uid}
    // Fields:
    //   - selections: list (objects)
    //   - score: number
    //   - is_valid: bool
    //   - last_updated: string (ISO)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email != null && (request.auth.token.email.lower() == "kebrahim@gmail.com" || request.auth.token.email.lower() == "kara.ebrahim@gmail.com")) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getContestData(contestId) {
      return exists(/databases/$(database)/documents/contests/$(contestId)) 
        ? get(/databases/$(database)/documents/contests/$(contestId)).data 
        : null;
    }

    function getStartTime(contestId) {
      let data = getContestData(contestId);
      return (data != null && 'start_time' in data)
        ? (data.start_time is timestamp ? data.start_time : timestamp(data.start_time))
        : timestamp("2099-01-01T00:00:00Z");
    }

    function isContestLocked(contestId) {
      return request.time >= getStartTime(contestId);
    }

    function isValidUser(data) {
      return data.display_name is string && data.display_name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             data.total_cp is number &&
             data.role in ['player', 'admin'];
    }

    function isValidEntry(data) {
      return data.selections is list &&
             data.score is number &&
             data.is_valid is bool;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'player';
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    // Team Lines
    match /team_lines/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Global Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Contests
    match /contests/{contestId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      // Allow draft updates for the current player
      allow update: if (
        isAuthenticated() && 
        resource.data.is_draft == true && 
        resource.data.draft_status == "in_progress" &&
        request.auth.uid == (
          (math.floor(resource.data.current_turn_index / resource.data.draft_order.size()) % 2 == 1)
            ? resource.data.draft_order[resource.data.draft_order.size() - 1 - (resource.data.current_turn_index % resource.data.draft_order.size())]
            : resource.data.draft_order[resource.data.current_turn_index % resource.data.draft_order.size()]
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["current_turn_index", "draft_status"])
      );

      // Entries
      match /entries/{entryUserId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(entryUserId) || isAdmin();
        allow delete: if isAdmin();
      }
    }
  }
}
